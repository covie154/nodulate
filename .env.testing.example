DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-testing-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
# Optional startup superuser bootstrap. Uncomment both username and password to create/promote this user at container startup.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=replace-with-a-long-random-admin-password
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_UPDATE_PASSWORD=0
DJANGO_SQLITE_PATH=/data/db.sqlite3
DJANGO_STATIC_ROOT=/vol/static
NODULATE_STORAGE_BACKEND=local
NODULATE_DATASET_ROOT=/dataset
NODULATE_DICOM_CACHE_ROOT=/vol/dicom-cache
NODULATE_LOCAL_DATASET_BIND=./dataset
DOMAIN=localhost
CERTBOT_EMAIL=admin@example.com