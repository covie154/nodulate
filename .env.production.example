DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_ALLOWED_HOSTS=labeler.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://labeler.example.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
# Optional startup superuser bootstrap. Uncomment both username and password to create/promote this user at container startup.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=replace-with-a-long-random-admin-password
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_UPDATE_PASSWORD=0
DJANGO_SQLITE_PATH=/data/db.sqlite3
DJANGO_STATIC_ROOT=/vol/static
NODULATE_STORAGE_BACKEND=s3
NODULATE_DICOM_CACHE_ROOT=/vol/dicom-cache
NODULATE_S3_BUCKET=your-private-dicom-bucket
NODULATE_S3_PREFIX=optional/prefix
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-if-not-using-ec2-instance-role
AWS_SECRET_ACCESS_KEY=replace-if-not-using-ec2-instance-role
DOMAIN=labeler.example.com
CERTBOT_EMAIL=admin@example.com